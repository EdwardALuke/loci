    char const * system_name,
    char const * options_prefix
  ) {
    if(created) return 0;

    LociPetscCall(VecCreate(MPI_COMM_WORLD, &v));
    if(Loci::MPI_processes > 1) {
      LociPetscCall(VecSetType(v, VECMPI));
    } else {
