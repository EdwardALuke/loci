#include <queue>
#include <vector>
#include <utility>
#include <list>
#include <bitset>
#include "diamondcell.h"
#include <Loci.h>
#include <algorithm>
using std::list;
using std::queue;

using std::cerr;
using std::endl;
using std::cout;

$include "FVM.lh"
$include "fvmadapt_internal.lh"

$rule pointwise(balancedFacePlan1 <- (cl, cr)->balancedCellPlan1, face2node,
(cl, cr)->(lower, upper, boundary_map)->face2node->(pos, fileNumber(pos)),
(cl, cr)->(lower, upper, boundary_map)->face2edge->edge2node->pos),
constraint(interior_faces, (cl, cr)->gnrlcells) {
  $balancedFacePlan1.clear() ;

  std::vector<char> facePlanL = extract_general_face($cl->$lower.begin(),
                                                     $cl->$lower.size(),
                                                     $cl->$upper.begin(),
                                                     $cl->$upper.size(),
                                                     $cl->$boundary_map.begin(),
                                                     $cl->$boundary_map.size(),
                                                     $*face2node,
                                                     $*face2edge,
                                                     $*edge2node,
                                                     $cl->$balancedCellPlan1,
                                                     _e_,
                                                     $*fileNumber(pos)) ;

  std::vector<char> facePlanR = extract_general_face($cr->$lower.begin(),
                                                     $cr->$lower.size(),
                                                     $cr->$upper.begin(),
                                                     $cr->$upper.size(),
                                                     $cr->$boundary_map.begin(),
                                                     $cr->$boundary_map.size(),
                                                     $*face2node,
                                                     $*face2edge,
                                                     $*edge2node,
                                                     $cr->$balancedCellPlan1,
                                                     _e_,
                                                     $*fileNumber(pos)) ;

  $balancedFacePlan1 = merge_faceplan(facePlanL, facePlanR, $face2node.size()) ;
  reduce_vector($balancedFacePlan1) ;
}

$rule pointwise(balancedFacePlan1 <- cl->balancedCellPlan1,
cl->(lower, upper, boundary_map)->face2node->(pos, fileNumber(pos)),
cl->(lower, upper, boundary_map)->face2edge->edge2node->pos),
constraint(boundary_faces, cl->gnrlcells) {
  $balancedFacePlan1 = extract_general_face($cl->$lower.begin(),
                                           $cl->$lower.size(),
                                           $cl->$upper.begin(),
                                           $cl->$upper.size(),
                                           $cl->$boundary_map.begin(),
                                           $cl->$boundary_map.size(),
                                           $*face2node,
                                           $*face2edge,
                                           $*edge2node,
                                           $cl->$balancedCellPlan1,
                                           _e_,
                                           $*fileNumber(pos)) ;
  reduce_vector($balancedFacePlan1) ;
}
