/// Merge derefinement face plans between a general cell on the left and a
/// prism cell on the right.
$rule pointwise(balancedFacePlan1 <- (cl, cr)->balancedCellPlan1,
face2node, cr->prismOrientCode, fr,
cl->(lower, upper, boundary_map)->face2node->(pos, fileNumber(pos)),
cl->(lower, upper, boundary_map)->face2edge->edge2node->pos),
constraint(cl->gnrlcells, cr->prisms) {
  $balancedFacePlan1.clear() ;

  std::vector<char> localPlanL = extract_general_face($cl->$lower.begin(),
                                                      $cl->$lower.size(),
                                                      $cl->$upper.begin(),
                                                      $cl->$upper.size(),
                                                      $cl->$boundary_map.begin(),
                                                      $cl->$boundary_map.size(),
                                                      $*face2node,
                                                      $*face2edge,
                                                      $*edge2node,
                                                      $cl->$balancedCellPlan1,
                                                      _e_,
                                                      $*fileNumber(pos)) ;

  if ($fr < 2) {
    std::vector<char> facePlanR = merge_tri_face_p($cr->$balancedCellPlan1,
                                                   $fr,
                                                   $cr->$prismOrientCode[$fr]) ;
    $balancedFacePlan1 = merge_faceplan(localPlanL, facePlanR,
                                        $face2node.size()) ;
  } else {
    std::vector<char> facePlanR = extract_prism_face($cr->$balancedCellPlan1,
                                                     $fr) ;
    std::vector<char> facePlanL = transfer_plan_g2q(localPlanL) ;
    $balancedFacePlan1 = merge_quad_face(facePlanL, char(0),
                                         facePlanR,
                                         $cr->$prismOrientCode[$fr]) ;
  }
  reduce_vector($balancedFacePlan1) ;
}

