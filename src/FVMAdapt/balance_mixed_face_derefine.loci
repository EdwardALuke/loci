/// Merge derefinement face plans between a hexahedral cell on the left and a
/// general cell on the right.
$rule pointwise(balancedFacePlan1 <- (cl, cr)->balancedCellPlan1,
cl->hexOrientCode, fl,
cr->(lower, upper, boundary_map)->face2node->(pos, fileNumber(pos)),
cr->(lower, upper, boundary_map)->face2edge->edge2node->pos),
constraint(cr->gnrlcells, cl->hexcells) {
  $balancedFacePlan1.clear() ;

  std::vector<char> localPlanR = extract_general_face($cr->$lower.begin(),
                                                      $cr->$lower.size(),
                                                      $cr->$upper.begin(),
                                                      $cr->$upper.size(),
                                                      $cr->$boundary_map.begin(),
                                                      $cr->$boundary_map.size(),
                                                      $*face2node,
                                                      $*face2edge,
                                                      $*edge2node,
                                                      $cr->$balancedCellPlan1,
                                                      _e_,
                                                      $*fileNumber(pos)) ;
  std::vector<char> facePlanR = transfer_plan_g2q(localPlanR) ;
  std::vector<char> facePlanL = extract_hex_face($cl->$balancedCellPlan1,
                                                 DIRECTION($fl)) ;

  $balancedFacePlan1 = merge_quad_face(facePlanR, char(0),
                                       facePlanL, $cl->$hexOrientCode[$fl]) ;
  reduce_vector($balancedFacePlan1) ;
}

