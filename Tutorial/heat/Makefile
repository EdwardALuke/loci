# This is a default makefile for Loci applications, just set LOCI_BASE
# and the executable name TARGET and this makefile will compile and link
# all Loci and other source files into a executable.
#########################################################################
# Set the LOCI_BASE environment variable to the location where Loci was
# installed for this makefile to work properly, or alternatively set the
# variable below:
# LOCI_BASE ?= /opt/loci
#########################################################################
# This will by default include all '.loci' files in the current directory
FILES = $(AUTOMATIC_FILES)
# List the name of your compiled program here
TARGET = heat

# Where to search for application specific include files
INCLUDES = -I./include
# Any additional local library linkage options go here
LOCAL_LIBS =

#############################################################################
# No changes needed below this line

include $(LOCI_BASE)/Loci.conf

default:
	$(MAKE) $(TARGET)

# Get all files that can be compiled into a Loci executable
AUTOMATIC_FILES = $(call loci_compile_files,)
# Convert list of files into their linker object files
AUTOMATIC_OBJS = $(call loci_file2objs,$(FILES))

# List all files that need to be linked to produce executable
OBJS := $(AUTOMATIC_OBJS)

$(TARGET): $(OBJS)
	$(LD) -o $(TARGET) $(OBJS) $(LOCAL_LIBS) $(LIBS) $(LDFLAGS)


# clean object files and target executable
clean:
	rm -fr $(OBJS) $(TARGET) 

# Find the intermediate files that are generated by the Loci preprocessor
LOCI_FILES = $(wildcard *.loci)
LOCI_LPP_FILES = $(LOCI_FILES:.loci=.$(LPP_I_SUFFIX))

# Junk files that are created while editing and running cases
JUNK = $(wildcard *~) $(wildcard crash_dump.*)  core debug output 

# dependency files that are automatically generated to create include file
# dependencies for make
DEPEND_FILES=$(subst .o,.d,$(OBJS))

distclean: clean
	rm -f $(DEPEND_FILES) $(LOCI_LPP_FILES)
	rm -fr $(JUNK)


#include automatically generated dependencies
ifeq ($(filter $(MAKECMDGOALS),clean distclean ),)
-include $(DEPEND_FILES)
endif
