# Make a copy of an entire directory structure to target using symbolic links
# for files
copy_with_symlinks() {
    local src=$1
    local dst=$2
    if [ ! -d "$src" ]; then
        echo "Error: $src is not a directory."
        return 1
    fi

    mkdir -p "$dst"
    
    while IFS= read -r -d '' file; do
        local rel_path="${file#$src/}"
        local target_path="$dst/$rel_path"

        # if file does not exist 
        if [ ! -f "$target_path" ]; then
            local target_dir=$(dirname "$target_path")
            # if directory doesn't exist, make it
            if [ ! -d "$target_dir" ]; then
                mkdir -p "$target_dir"
            fi
            ln -s "$file" "$target_path"
        fi
    done < <(find "$src" \( -path "$src/doxygen/html" \
                         -o -path "$src/doxygen/latex" \) -prune \
                  -o -type f \( -name '*.cc' -o -name '*.cpp' \
                  -o -name '*.c' -o -name '*.loci' -o -name '*.sh' \
                  -o -name '*.h' -o -name '*.hh' -o -name '*.lh' \
                  -o -name '*.hpp' -o -name '*.md' \
                  -o -name '*.tex' -o -name '*.eps' -o -name '*.pdf' \
                  -o -name '*.png' -o -name '*.svg' -o -name '*.html' \
                  -o -name '*.css' -o -name '*.obj' -o -name '*.sty' \
                  -o -name '*.txt' -o -name '*.dat' -o -name '*.vog'\
                  -o -name '*.vars' -o -name Makefile \
                  -o -name Doxyfile -o -name clean \
                  -o -name example_grid -o -name Loci -o -name overset \) -print0)
}

